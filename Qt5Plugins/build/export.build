$out_root/
{
  include plugins/platforms/
  include plugins/platforminputcontexts/
}

switch $import.target
{
  case lib{qxcb}
    dir = platforms
  case lib{composeplatforminputcontextplugin}
    dir = platforminputcontexts
  default
    fail "unknown target $import.target"
}

export $out_root/plugins/$dir/$import.target
